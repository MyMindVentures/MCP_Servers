{
  "name": "mcp-server-template",
  "version": "0.1.0",
  "private": true,
  "description": "Reusable Node.js/TypeScript MCP Server Template with MCP and OpenAI-compatible endpoints.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/sensible": "^5.0.1",
    "fastify": "^5.8.1",
    "fastify-plugin": "^5.0.0",
    "prom-client": "^15.0.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8",
    "@apidevtools/swagger-parser": "^10.0.3",
    "undici": "^6.19.8",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18",
    "tsx": "^4.19.0",
    "pino-pretty": "^11.2.0"
  }
}
